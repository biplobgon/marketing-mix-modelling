# =============================================================================
# Marketing Mix Modelling — .gitignore
# =============================================================================

# --- Raw data (download via Kaggle API; never commit) ---
data/raw/
data/raw/*

# --- Serialised model outputs (large binary files) ---
outputs/models/
outputs/models/*

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# --- Virtual environments ---
venv/
env/
.venv/
.env/
ENV/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints
.jupyter/

# --- R ---
.Rhistory
.RData
.Rproj.user/
*.Rproj

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- dotenv ---
.env
*.env

# --- Logs ---
*.log
logs/

# --- Coverage ---
.coverage
htmlcov/
.pytest_cache/

# --- Streamlit ---
.streamlit/secrets.toml
